{
  "name": "ambire-mobile-wallet",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "android:production": "APP_ENV=production yarn android",
    "ios": "expo run:ios",
    "ios:production": "APP_ENV=production yarn ios",
    "web:webkit": "rm -rf ./build/webkit-dev && WEB_ENGINE=webkit WEBPACK_BUILD_OUTPUT_PATH=webkit-dev APP_ENV=development EXPO_OS=web expo start --web",
    "web:next:webkit": "AMBIRE_NEXT=true yarn web:webkit",
    "web:safari": "./scripts/safari-dev-build.sh",
    "web:gecko": "rm -rf ./build/gecko-dev && WEB_ENGINE=gecko WEBPACK_BUILD_OUTPUT_PATH=gecko-dev APP_ENV=development EXPO_OS=web expo start --web",
    "web:benzin": "rm -rf ./build/benzin-dev && WEBPACK_BUILD_OUTPUT_PATH=benzin-dev APP_ENV=development BENZIN=true RCT_METRO_PORT=3006 WEB_PORT=3000 EXPO_OS=web expo start --web",
    "web:legends": "rm -rf ./build/legends-dev && LEGENDS=true WEBPACK_BUILD_OUTPUT_PATH=legends-dev APP_ENV=development RCT_METRO_PORT=3006 WEB_PORT=3000 EXPO_OS=web expo start --web",
    "dev:web:gecko": "REMOTE_CONTROL=headless WEB_ENGINE=gecko WEBPACK_BUILD_OUTPUT_PATH=gecko-dev APP_ENV=development EXPO_OS=web expo export:web",
    "start": "expo start --dev-client",
    "start:clean": "expo start --clear",
    "start:production": "APP_ENV=production yarn start",
    "start:clean:production": "APP_ENV=production yarn start:clean",
    "build:ios:simulator": "APP_ENV=production xcodebuild -workspace ios/ambire.xcworkspace -scheme Ambire -configuration Release -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath ios/build",
    "build:ios:simulator:install": "xcrun simctl install booted ios/build/Build/Products/Release-iphonesimulator/Ambire.app",
    "build:ios:archive": "APP_ENV=production xcodebuild -workspace ios/ambire.xcworkspace -scheme Ambire -configuration Release -sdk iphoneos -destination 'generic/platform=iOS' -archivePath ios/build/Ambire.xcarchive -derivedDataPath ios/build archive",
    "build:ios:export": "xcodebuild -exportArchive -archivePath ios/build/Ambire.xcarchive -exportPath ios/build/ipa -exportOptionsPlist ios/ExportOptions.plist",
    "build:ios:export-for-testing": "xcodebuild -exportArchive -archivePath ios/build/Ambire.xcarchive -exportPath ios/build/ipa-for-testing -exportOptionsPlist ios/ExportOptions-Development.plist",
    "build:ios:production": "yarn build:ios:archive && yarn build:ios:export",
    "build:ios:production-for-testing": "yarn build:ios:archive && yarn build:ios:export-for-testing",
    "build:android:production:apk": "cd android && APP_ENV=production ./gradlew assembleRelease",
    "build:android:production:aab": "cd android && APP_ENV=production ./gradlew bundleRelease",
    "build:web:webkit": "rm -rf ./build/webkit-prod && APP_ENV=production WEB_ENGINE=webkit WEBPACK_BUILD_OUTPUT_PATH=webkit-prod expo export:web",
    "build:web:webkit:generate-policy": "LAVAMOAT_GENERATE_POLICY=true yarn build:web:webkit",
    "build:web:next:webkit": "AMBIRE_NEXT=true yarn build:web:webkit",
    "build:web:safari": "./scripts/safari-prod-build.sh",
    "build:web:gecko": "rm -rf ./build/gecko-prod && APP_ENV=production WEB_ENGINE=gecko WEBPACK_BUILD_OUTPUT_PATH=gecko-prod expo export:web",
    "build:extensions": "sh ./scripts/build-extensions.sh",
    "build:extensions:gecko": "sh ./scripts/build-extensions.sh --gecko",
    "build:extensions:webkit": "sh ./scripts/build-extensions.sh --webkit",
    "build:extensions:next:webkit": "AMBIRE_NEXT=true yarn build:extensions:webkit",
    "build:web:benzin": "rm -rf ./build/benzin-prod && APP_ENV=production BENZIN=true WEBPACK_BUILD_OUTPUT_PATH=benzin-prod expo export:web",
    "build:web:legends": "rm -rf ./build/legends-prod && LEGENDS=true WEBPACK_BUILD_OUTPUT_PATH=legends-prod expo export:web",
    "export:web:webkit:sourcemaps": "sh ./scripts/export-source-maps.sh webkit",
    "export:web:gecko:sourcemaps": "sh ./scripts/export-source-maps.sh gecko",
    "publish:development": "expo publish --release-channel development",
    "publish:staging": "APP_ENV=staging expo publish --release-channel staging",
    "publish:production": "APP_ENV=production expo publish --release-channel default",
    "lint:fix": "eslint ./src/** --ext .js,.jsx,.ts,.tsx --fix",
    "expo:doctor": "expo doctor",
    "expo:upgrade": "expo upgrade",
    "expo:install": "expo install",
    "test": "jest --config=./jest.config.js --passWithNoTests",
    "extension:type:check": "tsc --noEmit --project tsconfig.typecheck-extension.json",
    "extension:type:check-new": "yarn extension:type:check | yarn tsc-baseline check",
    "setup": "yarn install && yarn allow-scripts && yarn patch-package",
    "setup:ci": "yarn install --frozen-lockfile && yarn allow-scripts && yarn patch-package"
  },
